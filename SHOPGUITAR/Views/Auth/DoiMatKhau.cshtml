@model SHOPGUITAR.Models.AuthModel.DoiMatKhauModel

@{
    ViewBag.Title = "Đổi mật khẩu";
    Layout = "~/Views/Shared/_Auth.cshtml";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="card p-4 shadow-lg border-0" style="width: 100%; max-width: 450px; border-radius: 15px; background: #ffffff;">

        <div class="text-center mb-4">
            <img src="~/Images/Chung/logo.png" alt="logo" /> <h4 class="fw-bold text-uppercase" style="color: #2b2b2b; letter-spacing: 0.5px; font-size: 1.3rem;">
                Đổi mật khẩu bảo mật
            </h4>
        </div>

        @if (ViewBag.Success != null)
        {
            <div class="alert alert-success text-center border-0 small mb-3" style="border-radius: 8px;">
                <i class="fa-solid fa-circle-check me-1"></i> @ViewBag.Success
            </div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center border-0 small mb-3" style="border-radius: 8px;">
                <i class="fa-solid fa-circle-exclamation me-1"></i> @ViewBag.Error
            </div>
        }

        @using (Html.BeginForm("DoiMatKhau", "Auth", FormMethod.Post, new { @class = "w-100" }))
        {
            @Html.AntiForgeryToken()

            <div class="form-group mb-3">
                <label class="form-label small fw-bold text-secondary text-uppercase" style="font-size: 0.75rem;">Mật khẩu hiện tại</label>
                @Html.PasswordFor(m => m.MatKhauCu, new
                {
                    @class = "form-control py-2 px-3",
                    placeholder = "Nhập mật khẩu đang dùng",
                    required = "required",
                    style = "border-radius: 8px; border: 1px solid #ced4da;"
                })
            </div>

            <div class="form-group mb-3">
                <label class="form-label small fw-bold text-secondary text-uppercase" style="font-size: 0.75rem;">Mật khẩu mới</label>
                @Html.PasswordFor(m => m.MatKhauMoi, new
                {
                    @class = "form-control py-2 px-3",
                    placeholder = "Nhập mật khẩu mới (ít nhất 6 ký tự)",
                    required = "required",
                    style = "border-radius: 8px; border: 1px solid #ced4da;"
                })
            </div>

            <div class="form-group mb-4">
                <label class="form-label small fw-bold text-secondary text-uppercase" style="font-size: 0.75rem;">Xác nhận mật khẩu mới</label>
                @Html.PasswordFor(m => m.XacNhanMatKhau, new
                {
                    @class = "form-control py-2 px-3",
                    placeholder = "Nhập lại mật khẩu mới",
                    required = "required",
                    style = "border-radius: 8px; border: 1px solid #ced4da;"
                })
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn text-white fw-bold py-2" style="background-color: #8B322C; border-radius: 8px; transition: all 0.3s;">
                    Cập nhật mật khẩu
                </button>
                <a href="@Url.Action("Index", "Home")" class="btn btn-link text-decoration-none text-secondary small text-center mt-1">
                    <i class="fa-solid fa-arrow-left me-1"></i> Quay lại trang chủ
                </a>
            </div>
        }
    </div>
</div>

<style>
    .btn:hover {
        filter: brightness(1.2);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

    .form-control:focus {
        border-color: #8B322C !important;
        box-shadow: 0 0 0 0.2rem rgba(139, 50, 44, 0.2) !important;
    }
</style>