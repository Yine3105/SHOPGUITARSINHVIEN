@model SHOPGUITAR.Models.SANPHAM
<link href="~/Content/Layout/Guitar.css" rel="stylesheet" />

@{
    ViewBag.Title = "Delete";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}

<div class="modal-backdrop">

    <div class="modal-box">

        <div class="modal-icon">

            <svg width="26"
                 height="26"
                 fill="none"
                 viewBox="0 0 24 24"
                 stroke="currentColor"
                 stroke-width="2">

                <path stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>

        </div>

        <h2 class="delete-title">
            Xác nhận xoá sản phẩm?
        </h2>

        <p class="delete-text">
            Sản phẩm
            <strong>@Model.TenSP</strong>
            sẽ bị xoá vĩnh viễn và không thể khôi phục lại.
        </p>

        <div class="product-info">

            <div class="info-row">
                <span class="label">Mã sản phẩm</span>
                <span class="value code">@Model.MaSP</span>
            </div>

            <div class="info-row">
                <span class="label">Tên sản phẩm</span>
                <span class="value">@Model.TenSP</span>
            </div>

            <div class="info-row">
                <span class="label">Mô tả</span>
                <span class="value">@Model.MoTaSP</span>
            </div>

        </div>

        <div class="warning-box">
            ⚠ Hành động này không thể hoàn tác. Hãy chắc chắn trước khi xoá.
        </div>

        <div class="modal-actions">

            <a href="@Url.Action("Index", "SanPham")"
               class="btn-cancel">
                Không, giữ lại
            </a>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <button type="submit"
                        class="btn-delete-confirm">
                    🗑 Có, xoá luôn!
                </button>
            }

        </div>

    </div>

</div>