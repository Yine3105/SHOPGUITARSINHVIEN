@model IEnumerable<SHOPGUITAR.Models.CTKIEMKE>
@{
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
    ViewBag.Title = "Chi Tiết Kiểm Kê";
}

<div class="content-area p-4">
    <h3 class="text-info mb-4">ĐỐI CHIẾU SỐ LIỆU TỒN KHO (BB: <span class="text-danger">@ViewBag.SoBBKK</span>)</h3>

    <div class="card p-3 border-info mb-4 bg-light">
        @using (Html.BeginForm("ChiTietKiemKe", "QuanLySanPham", FormMethod.Post))
        {
            <input type="hidden" name="SoBBKK" value="@ViewBag.SoBBKK" />
            <div class="row align-items-end">
                <div class="col-md-3">
                    <label class="font-weight-bold">Sản Phẩm Cần Đếm:</label>
                    @Html.DropDownList("MaSP", null, new { @class = "form-control" })
                </div>
                <div class="col-md-3">
                    <label class="font-weight-bold text-primary">SL Đếm Thực Tế Tại Kệ:</label>
                    <input type="number" name="SLThucTe" class="form-control" required min="0" value="0" />
                </div>
                <div class="col-md-4">
                    <label class="font-weight-bold">Đánh Giá Phẩm Chất (Tốt/Kém):</label>
                    <input type="text" name="PhamChat" class="form-control" placeholder="Ví dụ: Tốt" required />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-info w-100 text-white font-weight-bold"><i class="fa-solid fa-check"></i> Lưu Số Liệu</button>
                </div>
            </div>
        }
    </div>

    <table class="table table-bordered table-hover bg-white text-center">
        <thead class="thead-dark">
            <tr>
                <th>Mã SP</th>
                <th>Sổ Sách (Máy)</th>
                <th>Thực Tế Đếm</th>
                <th class="text-success">Thừa</th>
                <th class="text-danger">Thiếu</th>
                <th>Phẩm Chất</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ct in Model)
            {
                <tr>
                    <td>@ct.MaSP</td>
                    <td class="font-weight-bold">@ct.SLSoSach</td>
                    <td class="font-weight-bold text-primary">@ct.SLThucTe</td>
                    <td class="text-success font-weight-bold">@ct.SLThua</td>
                    <td class="text-danger font-weight-bold">@ct.SLThieu</td>
                    <td>@ct.PhamChat</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="alert alert-warning mt-3">
        <i class="fa-solid fa-bell"></i> <strong>Lưu ý:</strong> Biên bản này sẽ được tự động chuyển sang trạng thái "Chờ duyệt". Bạn cần thông báo cho Quản Lý Kho duyệt để cân bằng lại số lượng.
    </div>

    <div class="mt-3 text-right">
        <a href="@Url.Action("TonKho")" class="btn btn-primary px-5">Gửi Yêu Cầu Duyệt</a>
    </div>
</div>