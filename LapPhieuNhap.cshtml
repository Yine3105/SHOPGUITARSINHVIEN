@model SHOPGUITAR.Models.PHIEUNHAP
@{
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
    ViewBag.Title = "Quản lý tồn kho";
}

<div>
    <div class="banner">
        <div class="banner-logo">
            <img src="~/Images/Chung/logo.png" alt="logo" />
            <h5>GUITAR <br /> SINH VIÊN</h5>
        </div>
        <div class="search-form">
            <input type="text" name="keyword" placeholder="Tìm kiếm sản phẩm..." />
            <button type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
        </div>
        <div class="user-dropdown">
            <button class="banner-dangnhap">
                <i class="fa-solid fa-user"></i>
                <span>Xin chào, @(Session["HoTen"] ?? "Admin")</span>
            </button>
        </div>
    </div>

    <div class="main-container">
        <div class="sidebar">
            <ul>
                <li><a href="@Url.Action("Index", "Home")">Trang chủ</a></li>
                <li><a href="#">Quản lý đơn hàng</a></li>
                <li class="active"><a href="@Url.Action("TonKho", "QuanLySanPham")">Quản lý sản phẩm</a></li>
                <li><a href="#">Quản lý khách hàng</a></li>
            </ul>
        </div>

        <div class="content-area p-4">
            <h3 class="text-primary mb-4">LẬP PHIẾU NHẬP KHO</h3>
            <div class="card p-4 shadow-sm">
                @using (Html.BeginForm("LapPhieuNhap", "QuanLySanPham", FormMethod.Post))
                {
                    <div class="form-group mb-3">
                        <label class="font-weight-bold">Số Phiếu Nhập:</label>
                        @Html.TextBoxFor(m => m.SoPN, new { @class = "form-control", required = "required", placeholder = "Nhập mã hóa đơn từ NSX..." })
                    </div>
                    <div class="form-group mb-3">
                        <label class="font-weight-bold">Nhà Cung Cấp:</label>
                        <div class="d-flex">
                            @Html.DropDownList("MaNCC", null, "--- Chọn Nhà Cung Cấp ---", new { @class = "form-control mr-2", required = "required" })

                            <a href="@Url.Action("ThemNhaCungCap", "QuanLySanPham")" target="_blank" class="btn btn-outline-success mr-2 text-nowrap">
                                <i class="fa-solid fa-plus"></i> Thêm Mới
                            </a>

                            <a href="" class="btn btn-outline-info text-nowrap" title="Nhấn để cập nhật danh sách">
                                <i class="fa-solid fa-rotate-right"></i> Tải lại
                            </a>
                        </div>
                    </div>
                    <div class="form-group mb-4">
                        <label class="font-weight-bold">Tên Người Giao Hàng:</label>
                        @Html.TextBoxFor(m => m.NguoiGiao, new { @class = "form-control", required = "required" })
                    </div>
                    <button type="submit" class="btn btn-primary px-4">Tạo Phiếu & Tiếp Tục Thêm Hàng <i class="fa-solid fa-arrow-right"></i></button>
                    <a href="@Url.Action("TonKho")" class="btn btn-secondary">Hủy</a>
                }
            </div>
        </div>
    </div>
</div>