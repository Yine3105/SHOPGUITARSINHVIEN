@model List<SHOPGUITAR.Models.DONHANG>
@{
    ViewBag.Title = "Báo Cáo Doanh Thu";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}

<style>
    .bg-guitar-main {
        background-color: #8B322C !important;
    }

    .text-guitar-main {
        color: #8B322C !important;
    }

    .border-guitar-main {
        border-color: #8B322C !important;
    }

    .card-stat {
        border-radius: 10px;
        transition: all 0.3s ease;
        border: none;
    }

    .card-stat:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.08) !important;
    }

    /* Badge Pastel thanh lịch */
    .badge-soft-success {
        background-color: #d1e7dd;
        color: #0f5132;
    }

    .badge-soft-primary {
        background-color: #cfe2ff;
        color: #084298;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="p-4" style="background: #f4f6f9; min-height: 80vh;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold text-dark m-0"><i class="fa-solid fa-chart-line me-2 text-guitar-main"></i> BÁO CÁO DOANH THU BÁN HÀNG</h4>
            <small class="text-muted">Phân tích tình hình doanh số thực tế của SV Music Center</small>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("XuatPdfDoanhThu", "ThongKe", new { tuNgay = ViewBag.TuNgay, denNgay = ViewBag.DenNgay })" class="btn text-white shadow-sm fw-bold" style="background-color: #343a40; border-radius: 20px; padding: 6px 15px;">
                <i class="fa-solid fa-print me-1"></i> Xuất Biểu mẫu (PDF)
            </a>
            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary btn-sm px-3 bg-white" style="border-radius: 20px; padding: 6px 15px;">
                <i class="fa-solid fa-house me-1"></i> Về trang chủ
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4" style="border-radius: 10px;">
        <div class="card-body p-3">
            <form method="GET" action="@Url.Action("DoanhThu", "ThongKe")" class="row align-items-end g-3 m-0">
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-secondary mb-1">Từ ngày</label>
                    <input type="date" name="tuNgay" class="form-control" value="@ViewBag.TuNgay"
                           max="@DateTime.Now.ToString("yyyy-MM-dd")" style="border-radius: 6px; border-color: #e0e0e0;" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-secondary mb-1">Đến ngày</label>
                    <input type="date" name="denNgay" class="form-control" value="@ViewBag.DenNgay"
                           max="@DateTime.Now.ToString("yyyy-MM-dd")" style="border-radius: 6px; border-color: #e0e0e0;" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn text-white bg-guitar-main fw-bold w-100" style="border-radius: 6px; padding: 0.45rem 1rem;">
                        <i class="fa-solid fa-filter me-1"></i> Trích xuất báo cáo
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card card-stat shadow-sm bg-white p-3 border-top border-4 border-guitar-main">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold">Tổng doanh thu</h6>
                        <h3 class="fw-bold m-0 text-guitar-main">@string.Format("{0:N0}", ViewBag.TongDoanhThu) <span class="fs-6 fw-normal">đ</span></h3>
                    </div>
                    <div class="p-3 rounded-circle fs-4 text-guitar-main" style="background-color: rgba(139, 50, 44, 0.1);">
                        <i class="fa-solid fa-sack-dollar"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card card-stat shadow-sm bg-white p-3 border-top border-4 border-success">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold">Đơn hàng thành công</h6>
                        <h3 class="fw-bold m-0 text-success">@ViewBag.TongSoDon <span class="fs-6 fw-normal text-muted">đơn</span></h3>
                    </div>
                    <div class="p-3 rounded-circle fs-4 text-success" style="background-color: rgba(25, 135, 84, 0.1);">
                        <i class="fa-solid fa-receipt"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card card-stat shadow-sm bg-white p-3 border-top border-4 border-primary">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold">Giá trị trung bình/đơn</h6>
                        <h3 class="fw-bold m-0 text-primary">@string.Format("{0:N0}", ViewBag.TrungBinhDon) <span class="fs-6 fw-normal">đ</span></h3>
                    </div>
                    <div class="p-3 rounded-circle fs-4 text-primary" style="background-color: rgba(13, 110, 253, 0.1);">
                        <i class="fa-solid fa-calculator"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; overflow: hidden;">
        <div class="bg-white px-4 py-3 border-bottom d-flex align-items-center">
            <i class="fa-solid fa-chart-area me-2 text-guitar-main fs-5"></i>
            <h6 class="m-0 fw-bold text-dark">Biểu đồ xu hướng tăng trưởng doanh thu</h6>
        </div>
        <div class="card-body p-4 bg-white">
            <div style="width: 100%; height: 320px;">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="bg-white px-4 py-3 border-bottom d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center">
                <i class="fa-solid fa-list-check me-2 text-secondary fs-5"></i>
                <h6 class="m-0 fw-bold text-dark">Nhật ký đơn hàng đã đối soát</h6>
            </div>
        </div>
        <div class="card-body p-0 bg-white">
            <div class="table-responsive">
                <table class="table table-hover align-middle m-0">
                    <thead class="bg-guitar-main text-white">
                        <tr>
                            <th class="ps-4 fw-bold" style="padding: 15px 10px;">Mã Đơn</th>
                            <th class="fw-bold">Ngày hoàn thành</th>
                            <th class="fw-bold">Khách hàng</th>
                            <th class="text-end fw-bold">Tổng thanh toán</th>
                            <th class="text-center pe-4 fw-bold">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var don in Model)
                            {
                                <tr style="border-bottom: 1px solid #f1f1f1;">
                                    <td class="fw-bold ps-4 text-secondary">#@don.MaDH</td>

                                    <td class="text-muted small">
                                        <i class="fa-regular fa-clock me-1"></i>
                                        @don.NgayDatHang.ToString("dd/MM/yyyy HH:mm")
                                    </td>

                                    <td class="fw-bold text-dark">
                                        <i class="fa-solid fa-circle-user text-secondary me-1"></i>
                                        @if (!string.IsNullOrEmpty(don.MaKH))
                                        {
                                            if (don.KHACHHANG != null)
                                            {
                                                <span>@don.KHACHHANG.TenKH <small class="text-muted fw-normal">(@don.MaKH)</small></span>
                                            }
                                            else
                                            {
                                                <span>Mã KH: @don.MaKH</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted fw-normal">Khách mua tại quầy</span>
                                        }
                                    </td>

                                    <td class="text-end fw-bold" style="color: #0f5132;">
                                        @{
                                            var dicTong = ViewBag.DicTongTien as Dictionary<string, decimal>;
                                            string idDon = don.MaDH.ToString();
                                            decimal tien = (dicTong != null && dicTong.ContainsKey(idDon)) ? dicTong[idDon] : 0;
                                        }
                                        @string.Format("{0:N0}", tien) đ
                                    </td>

                                    <td class="text-center pe-4">
                                        <span class="badge badge-soft-success px-3 py-2" style="border-radius: 6px;">
                                            <i class="fa-solid fa-check-circle me-1"></i> Đã thanh toán
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    <i class="fa-solid fa-file-invoice-dollar d-block fs-1 mb-2 text-secondary opacity-50"></i>
                                    Không phát sinh doanh thu trong khoảng thời gian này.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Lấy dữ liệu an toàn từ ViewBag
        var labelsData = @Html.Raw(ViewBag.ChartLabels ?? "[]");
        var revenueData = @Html.Raw(ViewBag.ChartData ?? "[]");

        var ctx = document.getElementById('revenueChart').getContext('2d');
        var myChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labelsData,
                datasets: [{
                    label: 'Doanh thu (VNĐ)',
                    data: revenueData,
                    borderColor: '#8B322C',
                    backgroundColor: 'rgba(139, 50, 44, 0.08)', 
                    borderWidth: 3,
                    tension: 0.4, 
                    fill: true,
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: '#8B322C',
                    pointBorderWidth: 2,
                    pointRadius: 5,
                    pointHoverRadius: 7
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }, 
                    tooltip: {
                        backgroundColor: '#343a40',
                        titleFont: { size: 13 },
                        bodyFont: { size: 14, weight: 'bold' },
                        padding: 12,
                        callbacks: {
                            label: function(context) {
                                return context.parsed.y.toLocaleString() + ' đ';
                            }
                        }
                    }
                },
                scales: {
                    x: { grid: { display: false } },
                    y: {
                        beginAtZero: true,
                        border: { dash: [5, 5] }, 
                        grid: { color: '#e9ecef' },
                        ticks: {
                            callback: function(value) {
                                return value.toLocaleString() + 'đ';
                            }
                        }
                    }
                }
            }
        });
    });
</script>