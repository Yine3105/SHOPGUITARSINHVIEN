@model List<SHOPGUITAR.Controllers.SanPhamBanChayViewModel>
@{
    ViewBag.Title = "Thống Kê Sản Phẩm Bán Chạy";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";

    // Khởi tạo giá trị bằng 0 an toàn nếu Model bị null
    decimal tongDoanhThu = Model != null ? Model.Sum(x => x.DoanhThu) : 0;
    int tongSPBan = Model != null ? Model.Sum(x => x.SoLuongBan) : 0;
}

<style>
    .bg-guitar-main {
        background-color: #8B322C !important;
    }

    .text-guitar-main {
        color: #8B322C !important;
    }

    .card-stat {
        border-radius: 10px;
        transition: all 0.3s ease;
        border: none;
    }

        .card-stat:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.08) !important;
        }
</style>

<div class="p-4" style="background: #f4f6f9; min-height: 80vh;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold text-dark m-0"><i class="fa-solid fa-fire me-2 text-guitar-main"></i> THỐNG KÊ SẢN PHẨM BÁN CHẠY</h4>
            <small class="text-muted">Danh sách các sản phẩm có số lượng tiêu thụ cao nhất</small>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("XuatPdfBanChay", "ThongKe", new { tuNgay = ViewBag.TuNgay, denNgay = ViewBag.DenNgay })" class="btn text-white shadow-sm fw-bold" style="background-color: #8B322C; border-radius: 20px; padding: 6px 15px;">
                <i class="fa-solid fa-print me-1"></i> Xuất Biểu mẫu (PDF)
            </a>
            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary btn-sm px-3 bg-white" style="border-radius: 20px; padding: 6px 15px;">
                <i class="fa-solid fa-house me-1"></i> Trở về
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4" style="border-radius: 10px;">
        <div class="card-body p-3">
            <form method="GET" action="@Url.Action("TopSP", "ThongKe")" class="row align-items-end g-3 m-0">
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-secondary mb-1">Từ ngày</label>
                    <input type="date" name="tuNgay" class="form-control" value="@ViewBag.TuNgay"
                           max="@DateTime.Now.ToString("yyyy-MM-dd")" style="border-radius: 6px;" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-secondary mb-1">Đến ngày</label>
                    <input type="date" name="denNgay" class="form-control" value="@ViewBag.DenNgay"
                           max="@DateTime.Now.ToString("yyyy-MM-dd")" style="border-radius: 6px;" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn text-white bg-guitar-main fw-bold w-100" style="border-radius: 6px;">
                        <i class="fa-solid fa-filter me-1"></i> Lọc báo cáo
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card card-stat shadow-sm bg-white p-3 border-top border-4 border-primary">
                <h6 class="text-muted text-uppercase small fw-bold">Tổng sản phẩm đã bán</h6>
                <h3 class="fw-bold m-0 text-primary">@string.Format("{0:N0}", tongSPBan) <span class="fs-6 fw-normal text-muted">sản phẩm</span></h3>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card card-stat shadow-sm bg-white p-3 border-top border-4 border-guitar-main">
                <h6 class="text-muted text-uppercase small fw-bold">Tổng doanh thu các sản phẩm</h6>
                <h3 class="fw-bold m-0 text-guitar-main">@string.Format("{0:N0}", tongDoanhThu) đ</h3>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="card-body p-0 bg-white">
            <div class="table-responsive">
                <table class="table table-hover align-middle m-0">
                    <thead class="bg-guitar-main text-white">
                        <tr>
                            <th class="ps-4 fw-bold" style="width: 15%;">Mã SP</th>
                            <th class="fw-bold" style="width: 35%;">Tên sản phẩm</th>
                            <th class="fw-bold" style="width: 15%;">Loại sản phẩm</th>
                            <th class="text-end fw-bold" style="width: 15%;">Giá bán</th>
                            <th class="text-center fw-bold" style="width: 10%;">Đã bán</th>
                            <th class="text-end pe-4 fw-bold" style="width: 10%;">Tổng doanh thu</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold ps-4 text-secondary">@item.MaSP</td>
                                    <td class="fw-bold text-dark">@item.TenSP</td>
                                    <td class="text-muted">@(string.IsNullOrEmpty(item.TenLoaiSP) ? "---" : item.TenLoaiSP)</td>
                                    <td class="text-end fw-bold">@string.Format("{0:N0}", item.GiaBan) đ</td>
                                    <td class="text-center fw-bold text-primary">@item.SoLuongBan</td>
                                    <td class="text-end pe-4 fw-bold text-guitar-main">@string.Format("{0:N0}", item.DoanhThu) đ</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="fa-solid fa-box-open d-block fs-1 mb-2 text-secondary opacity-50"></i>
                                    Không có sản phẩm nào được bán ra trong khoảng thời gian này.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>