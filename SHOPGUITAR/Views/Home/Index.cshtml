@model SHOPGUITAR.Models.HomeModel
@{
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
    ViewBag.Title = "Home Page";
}
<div>
    <div class="banner">
        <div class="banner-logo">
            <img src="~/Images/Chung/logo.png" alt="logo" />
            <h5>GUITAR <br /> SINH VIÊN</h5>
        </div>
        <div class="search-form">
            <input type="text" name="keyword" placeholder="Tìm kiếm sản phẩm..." />
            <button type="submit">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
        </div>
        <a href="#" class="banner-cart">
            <i class="fa-solid fa-cart-shopping"></i>
        </a>
        @if (Session["UserId"] == null)
        {
            <a href="/Auth/DangNhap" class="banner-dangnhap">
                <i class="fa-solid fa-user"></i>
                <span>Đăng nhập</span>
            </a>
        }
        else
        {
            <div class="user-dropdown">
                <button class="banner-dangnhap" onclick="toggleDropdown()">
                    <i class="fa-solid fa-user"></i>
                    <span>Xin chào, @Session["HoTen"]</span>
                </button>
                <div class="dropdown-menu-custom" id="userDropdown">
                    <a href="@Url.Action("DoiMatKhau", "Auth")">
                        <i class="fa-solid fa-key"></i> Đổi mật khẩu
                    </a>
                    <a href="/Auth/DangXuat">
                        <i class="fa-solid fa-right-from-bracket"></i> Đăng xuất
                    </a>
                </div>
            </div>
        }
    </div>

    <div class="main-container">

        @* Sidebar chỉ hiển thị với Nhân viên / Quản lý / Admin *@
        @if (Session["UserRole"] != null &&
            (Session["UserRole"].ToString() == "Admin" ||
             Session["UserRole"].ToString() == "Quản lý" ||
             Session["UserRole"].ToString() == "Quản lý kho" ||
             Session["UserRole"].ToString() == "Nhân viên kho" ||
             Session["UserRole"].ToString() == "Nhân viên bán hàng"))
        {
            var currentRole = Session["UserRole"].ToString();

            <div class="sidebar">
                <ul style="list-style: none; padding: 0; margin: 0;">

                    <li class="menu-title" style="padding: 12px 15px 6px 15px; font-size: 0.8rem; color: #FFE5B4; font-weight: 800; text-uppercase; letter-spacing: 1px; display: flex; align-items: center; gap: 6px;">
                        <i class="fa-solid fa-layer-group" style="font-size: 0.85rem; opacity: 0.8;"></i> TỔNG QUAN
                    </li>
                    <li><a href="@Url.Action("Index", "Home")"><i class="fa-solid fa-house me-2"></i> Trang chủ</a></li>

                    <li class="menu-title" style="padding: 18px 15px 6px 15px; font-size: 0.8rem; color: #FFE5B4; font-weight: 800; text-uppercase; letter-spacing: 1px; border-top: 1px solid rgba(255,255,255,0.1); margin-top: 12px; display: flex; align-items: center; gap: 6px;">
                        <i class="fa-solid fa-briefcase" style="font-size: 0.85rem; opacity: 0.8;"></i> NGHIỆP VỤ BÁN HÀNG
                    </li>
                    @if (currentRole == "Admin" || currentRole == "Quản lý" || currentRole == "Nhân viên bán hàng")
                    {
                        <li><a href="#"><i class="fa-solid fa-file-invoice-dollar me-2"></i> Quản lý đơn hàng</a></li>
                    }
                    @if (currentRole == "Admin" || currentRole == "Quản lý" || currentRole == "Quản lý kho" || currentRole == "Nhân viên kho")
                    {
                        <li><a href="#"><i class="fa-solid fa-guitar me-2"></i> Quản lý sản phẩm</a></li>
                    }
                    @if (currentRole == "Admin" || currentRole == "Quản lý")
                    {
                        <li><a href="#"><i class="fa-solid fa-users me-2"></i> Quản lý khách hàng</a></li>
                    }

                    @if (currentRole == "Admin" || currentRole == "Quản lý" || currentRole == "Quản lý kho" || currentRole == "Nhân viên kho")
                    {
                        <li class="menu-title" style="padding: 18px 15px 6px 15px; font-size: 0.8rem; color: #FFE5B4; font-weight: 800; text-uppercase; letter-spacing: 1px; border-top: 1px solid rgba(255,255,255,0.1); margin-top: 12px; display: flex; align-items: center; gap: 6px;">
                            <i class="fa-solid fa-chart-pie" style="font-size: 0.85rem; opacity: 0.8;"></i> BÁO CÁO & THỐNG KÊ
                        </li>

                        <li>
                            <a href="@Url.Action("TonKho", "ThongKe")">
                                <i class="fa-solid fa-boxes-stacked me-2"></i> Thống kê tồn kho
                            </a>
                        </li>

                        if (currentRole == "Admin" || currentRole == "Quản lý")
                        {
                            <li>
                                <a href="@Url.Action("DoanhThu", "ThongKe")">
                                    <i class="fa-solid fa-chart-line me-2"></i> Báo cáo doanh thu
                                </a>
                            </li>
                            <li>
                                <a href="@Url.Action("TopSP", "ThongKe")">
                                    <i class="fa-solid fa-fire me-2"></i> Sản phẩm bán chạy
                                </a>
                            </li>
                            <li>
                                <a href="@Url.Action("LoiNhuan", "ThongKe")">
                                    <i class="fa-solid fa-calculator me-2"></i> Báo cáo lợi nhuận
                                </a>
                            </li>
                        }
                    }

                    @if (currentRole == "Admin")
                    {
                        <li class="menu-title" style="padding: 18px 15px 6px 15px; font-size: 0.8rem; color: #FFE5B4; font-weight: 800; text-uppercase; letter-spacing: 1px; border-top: 1px solid rgba(255,255,255,0.1); margin-top: 12px; display: flex; align-items: center; gap: 6px;">
                            <i class="fa-solid fa-sliders" style="font-size: 0.85rem; opacity: 0.8;"></i> PHÂN QUYỀN
                        </li>
                        <li><a href="@Url.Action("PhanQuyen", "Admin")" style="color: #ffc107; font-weight: bold;"><i class="fa-solid fa-user-shield me-2"></i> Phân quyền hệ thống</a></li>
                    }
                </ul>
            </div>
        }

        <div class="content-area">
            @* Thanh loại sản phẩm *@
            <div class="loai-sanpham">
                <a href="@Url.Action("Index", "Home")"
                   class="loai-item @(Model.LoaiDangChon == null ? "active" : "")">
                    Tất cả
                </a>

                @foreach (var loai in Model.DanhSachLoai)
                {
                    <a href="@Url.Action("Index", "Home", new { maLoai = loai.MaLoaiSP })"
                       class="loai-item @(Model.LoaiDangChon == loai.MaLoaiSP ? "active" : "")">
                        @loai.TenLoaiSP
                    </a>
                }
            </div>

            @* Banner khuyến mãi *@
            <div class="khuyen-mai">
                <p>Chương trình khuyến mãi</p>
            </div>

            @* Danh sách sản phẩm *@
            <div class="sanpham-list">
                @if (Model.DanhSachSanPham != null && Model.DanhSachSanPham.Any())
                {
                    foreach (var sp in Model.DanhSachSanPham)
                    {
                        <a href="#" class="sanpham-card">
                            <div class="card-anh">
                                <img src="~/Images/SanPham/@sp.AnhSP" alt="@sp.TenSP" />
                            </div>
                            <div class="card-info">
                                <p class="card-ten">@sp.TenSP</p>
                                <p class="card-thuonghieu">@sp.ThuongHieu</p>
                                <p class="card-gia">@sp.GiaBan.ToString("N0") đ</p>
                                @if (sp.SoLuongSP > 0)
                                {
                                    <span class="card-trangthai con-hang">Còn hàng</span>
                                }
                                else
                                {
                                    <span class="card-trangthai het-hang">Hết hàng</span>
                                }
                            </div>
                        </a>
                    }
                }
                else
                {
                    <p class="empty-msg">Không có sản phẩm nào.</p>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function toggleDropdown() {
            var menu = document.getElementById('userDropdown');
            menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
        }

        document.addEventListener('click', function (e) {
            var dropdown = document.querySelector('.user-dropdown');
            if (dropdown && !dropdown.contains(e.target)) {
                document.getElementById('userDropdown').style.display = 'none';
            }
        });

        const currentPath = window.location.pathname.toLowerCase();
        document.querySelectorAll('.sidebar ul li a').forEach(function (a) {
            const href = a.getAttribute('href').toLowerCase();
            if (href === currentPath ||
                (currentPath === '/' && href.includes('home')) ||
                (currentPath.includes(href) && href !== '#')) {
                a.closest('li').classList.add('active');
            }
        });
    </script>
}