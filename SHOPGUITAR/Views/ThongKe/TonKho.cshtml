@model List<SHOPGUITAR.Models.VW_BaoCaoTonKho>
@{
    ViewBag.Title = "Thống Kê Tồn Kho";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
    string statusDangChon = ViewBag.TrangThaiDangChon;
}

<style>
    .bg-guitar-main {
        background-color: #8B322C !important;
    }

    .text-guitar-main {
        color: #8B322C !important;
    }

    .border-guitar-main {
        border-color: #8B322C !important;
    }

    .card-stat {
        border-radius: 10px;
        transition: all 0.3s ease;
        border: none;
    }

        .card-stat:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.08) !important;
        }

    .filter-btn {
        color: #6c757d;
        background: transparent;
        border: none;
        border-bottom: 2px solid transparent;
        font-weight: 600;
        padding: 10px 20px;
    }

        .filter-btn.active {
            color: #8B322C;
            border-bottom: 3px solid #8B322C;
        }

        .filter-btn:hover:not(.active) {
            color: #8B322C;
            opacity: 0.8;
        }

    .badge-soft-success {
        background-color: #d1e7dd;
        color: #0f5132;
    }

    .badge-soft-warning {
        background-color: #fff3cd;
        color: #856404;
    }

    .badge-soft-danger {
        background-color: #f8d7da;
        color: #842029;
    }
</style>

<div class="p-4" style="background: #f4f6f9; min-height: 80vh;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold text-dark m-0"><i class="fa-solid fa-boxes-stacked me-2 text-guitar-main"></i> THỐNG KÊ TỒN KHO NHẠC CỤ</h4>
            <small class="text-muted">Dữ liệu tổng hợp thời gian thực từ kho hàng SV Music Center</small>
        </div>

        <div class="d-flex gap-2">
            <a href="@Url.Action("XuatExcelTonKho", "ThongKe")" class="btn btn-sm text-white shadow-sm fw-bold" style="background-color: #198754; border-radius: 20px; padding: 6px 15px;">
                <i class="fa-solid fa-file-excel me-1"></i> Xuất Excel
            </a>
            <a href="@Url.Action("XuatPdfTonKho", "ThongKe")" class="btn btn-sm text-white shadow-sm fw-bold" style="background-color: #8B322C; border-radius: 20px; padding: 6px 15px;">
                <i class="fa-solid fa-file-pdf me-1"></i> Xuất PDF
            </a>
            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary btn-sm px-3 bg-white" style="border-radius: 20px; padding: 6px 15px;">
                <i class="fa-solid fa-house me-1"></i> Về trang chủ
            </a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card card-stat shadow-sm bg-white p-3 border-top border-4 border-guitar-main">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold">Tổng sản phẩm tồn kho</h6>
                        <h3 class="fw-bold m-0 text-guitar-main">@ViewBag.TongSoLuongTon <span class="fs-6 fw-normal">sản phẩm</span></h3>
                    </div>
                    <div class="p-3 rounded-circle fs-4 text-guitar-main" style="background-color: rgba(139, 50, 44, 0.1);">
                        <i class="fa-solid fa-warehouse"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <a href="@Url.Action("TonKho", "ThongKe", new { trangThaiHang = "SapHet" })" class="text-decoration-none">
                <div class="card card-stat shadow-sm bg-white p-3 border-top border-4 border-warning">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h6 class="text-muted text-uppercase small fw-bold">Sản phẩm sắp hết hàng</h6>
                            <h3 class="fw-bold m-0 text-warning">@ViewBag.SapHetHang <span class="fs-6 fw-normal">loại</span></h3>
                        </div>
                        <div class="p-3 rounded-circle fs-4 text-warning" style="background-color: rgba(255, 193, 7, 0.15);">
                            <i class="fa-solid fa-hourglass-half"></i>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4 mb-3">
            <a href="@Url.Action("TonKho", "ThongKe", new { trangThaiHang = "HetHang" })" class="text-decoration-none">
                <div class="card card-stat shadow-sm bg-white p-3 border-top border-4 border-danger">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h6 class="text-muted text-uppercase small fw-bold">Sản phẩm đã hết hàng</h6>
                            <h3 class="fw-bold m-0 text-danger">@ViewBag.DaHetHang <span class="fs-6 fw-normal">loại</span></h3>
                        </div>
                        <div class="p-3 rounded-circle fs-4 text-danger" style="background-color: rgba(220, 53, 69, 0.1);">
                            <i class="fa-solid fa-circle-xmark"></i>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="bg-white px-3 pt-2 d-flex justify-content-between align-items-end border-bottom">
            <div class="d-flex">
                <a href="@Url.Action("TonKho", "ThongKe")" class="text-decoration-none filter-btn @(string.IsNullOrEmpty(statusDangChon) ? "active" : "")">Tất cả kho</a>
                <a href="@Url.Action("TonKho", "ThongKe", new { trangThaiHang = "ConHang" })" class="text-decoration-none filter-btn @(statusDangChon == "ConHang" ? "active" : "")">Tồn kho ổn định</a>
                <a href="@Url.Action("TonKho", "ThongKe", new { trangThaiHang = "SapHet" })" class="text-decoration-none filter-btn @(statusDangChon == "SapHet" ? "active" : "")">Sắp hết hàng</a>
                <a href="@Url.Action("TonKho", "ThongKe", new { trangThaiHang = "HetHang" })" class="text-decoration-none filter-btn @(statusDangChon == "HetHang" ? "active" : "")">Đã hết hàng</a>
            </div>
            <p class="text-muted small mb-2 pb-2"><i class="fa-solid fa-list me-1"></i> Hiển thị @Model.Count sản phẩm</p>
        </div>

        <div class="card-body p-0 bg-white">
            <div class="table-responsive">
                <table class="table table-hover align-middle m-0">
                    <thead class="bg-guitar-main text-white">
                        <tr>
                            <th class="ps-4 fw-bold" style="width: 12%; padding: 15px 10px;">Mã SP</th>
                            <th class="fw-bold" style="width: 35%;">Tên nhạc cụ / Sản phẩm</th>
                            <th class="text-center fw-bold" style="width: 15%;">Số lượng tồn</th>
                            <th class="fw-bold" style="width: 20%;">Trạng thái kho</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold ps-4 text-secondary">@item.MaSP</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light border me-3 d-flex justify-content-center align-items-center text-secondary" style="width: 40px; height: 40px; border-radius: 6px;">
                                                <i class="fa-solid fa-guitar"></i>
                                            </div>
                                            <span class="fw-bold text-dark">
                                                @(string.IsNullOrEmpty(item.TenSP) ? "Chưa cập nhật tên..." : item.TenSP)
                                            </span>
                                        </div>
                                    </td>

                                    <td class="text-center fw-bold fs-6 @(item.TonKhoThucTe <= 0 ? "text-danger" : (item.TonKhoThucTe <= 5 ? "text-warning" : "text-dark"))">
                                        @item.TonKhoThucTe
                                    </td>

                                    <td>
                                        @if (item.TonKhoThucTe <= 0)
                                        {
                                            <span class="badge badge-soft-danger px-3 py-2" style="border-radius: 6px;">
                                                <i class="fa-solid fa-circle-xmark me-1"></i> Đã hết hàng
                                            </span>
                                        }
                                        else if (item.TonKhoThucTe <= 5)
                                        {
                                            <span class="badge badge-soft-warning px-3 py-2" style="border-radius: 6px;">
                                                <i class="fa-solid fa-triangle-exclamation me-1"></i> Sắp hết
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-soft-success px-3 py-2" style="border-radius: 6px;">
                                                <i class="fa-solid fa-check-circle me-1"></i> An toàn
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    <i class="fa-solid fa-box-open d-block fs-1 mb-2 text-secondary opacity-50"></i>
                                    Không tìm thấy dữ liệu sản phẩm nào.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>