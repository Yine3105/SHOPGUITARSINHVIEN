@model SHOPGUITAR.Models.BBKIEMNGHIEM
@{
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
    ViewBag.Title = "Lập Biên Bản Kiểm Nghiệm";
}

<div class="content-area p-4">
    <h3 class="text-warning mb-4"><i class="fa-solid fa-clipboard-check"></i> LẬP BIÊN BẢN KIỂM NGHIỆM </h3>
    <div class="card p-4 shadow-sm border-warning">
        @using (Html.BeginForm("LapBienBanKiemNghiem", "QuanLySanPham", FormMethod.Post))
        {
            <div class="form-group mb-4">
                <label class="font-weight-bold">Số Biên Bản (Mã số):</label>
                @Html.TextBoxFor(m => m.SoBBKN, new { @class = "form-control", required = "required", placeholder = "VD: BBKN005..." })
            </div>
            <button type="submit" class="btn btn-warning px-4 font-weight-bold"> Tạo Biên Bản <i class="fa-solid fa-arrow-right"></i></button>
            <a href="@Url.Action("TonKho")" class="btn btn-secondary">Hủy</a>
        }
    </div>
</div>