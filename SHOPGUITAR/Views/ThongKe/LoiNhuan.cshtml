@model List<SHOPGUITAR.Controllers.SanPhamBanChayViewModel>
@{
    ViewBag.Title = "Báo Cáo Lợi Nhuận";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";

    decimal tongDoanhThu = Model != null ? Model.Sum(x => x.DoanhThu) : 0;
    decimal tongLoiNhuan = Model != null ? Model.Sum(x => x.LoiNhuan) : 0;
}

<style>
    .bg-guitar-main {
        background-color: #8B322C !important;
    }

    .text-guitar-main {
        color: #8B322C !important;
    }

    .card-stat {
        border-radius: 10px;
        transition: all 0.3s ease;
        border: none;
    }

        .card-stat:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.08) !important;
        }
</style>

<div class="p-4" style="background: #f4f6f9; min-height: 80vh;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold text-dark m-0"><i class="fa-solid fa-calculator me-2 text-guitar-main"></i> BÁO CÁO LỢI NHUẬN TỪNG SẢN PHẨM</h4>
            <small class="text-muted">Đối soát giá trị chênh lệch giữa doanh số bán và giá gốc nhập hàng</small>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("XuatPdfLoiNhuan", "ThongKe", new { tuNgay = ViewBag.TuNgay, denNgay = ViewBag.DenNgay })" class="btn text-white shadow-sm fw-bold" style="background-color: #198754; border-radius: 20px; padding: 6px 15px;">
                <i class="fa-solid fa-print me-1"></i> Xuất Biểu mẫu (PDF)
            </a>
            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary btn-sm px-3 bg-white" style="border-radius: 20px;">
                <i class="fa-solid fa-house me-1"></i> Trở về
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4" style="border-radius: 10px;">
        <div class="card-body p-3">
            <form method="GET" action="@Url.Action("LoiNhuan", "ThongKe")" class="row align-items-end g-3 m-0">
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-secondary mb-1">Từ ngày</label>
                    <input type="date" name="tuNgay" class="form-control" value="@ViewBag.TuNgay"
                           max="@DateTime.Now.ToString("yyyy-MM-dd")" style="border-radius: 6px;" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-secondary mb-1">Đến ngày</label>
                    <input type="date" name="denNgay" class="form-control" value="@ViewBag.DenNgay"
                           max="@DateTime.Now.ToString("yyyy-MM-dd")" style="border-radius: 6px;" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn text-white bg-guitar-main fw-bold w-100" style="border-radius: 6px;">
                        <i class="fa-solid fa-filter me-1"></i> Tính toán lợi nhuận
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card card-stat shadow-sm bg-white p-3 border-top border-4 border-guitar-main">
                <h6 class="text-muted text-uppercase small fw-bold">Tổng doanh số bán hàng</h6>
                <h3 class="fw-bold m-0 text-guitar-main">@string.Format("{0:N0}", tongDoanhThu) đ</h3>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card card-stat shadow-sm bg-white p-3 border-top border-4 border-success">
                <h6 class="text-muted text-uppercase small fw-bold">Tổng số tiền lợi nhuận ròng</h6>
                <h3 class="fw-bold m-0 text-success">+ @string.Format("{0:N0}", tongLoiNhuan) đ</h3>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="card-body p-0 bg-white">
            <div class="table-responsive">
                <table class="table table-hover align-middle m-0">
                    <thead class="bg-guitar-main text-white">
                        <tr>
                            <th class="ps-4 fw-bold">Mã SP</th>
                            <th class="fw-bold">Tên nhạc cụ</th>
                            <th class="text-end fw-bold">Giá vốn nhập</th>
                            <th class="text-end fw-bold">Giá bán ra</th>
                            <th class="text-center fw-bold">SL bán</th>
                            <th class="text-end fw-bold">Tổng doanh thu</th>
                            <th class="text-end pe-4 fw-bold">Lợi nhuận ròng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold ps-4 text-secondary">@item.MaSP</td>
                                    <td class="fw-bold text-dark">@item.TenSP</td>
                                    <td class="text-end text-muted">@string.Format("{0:N0}", item.GiaNhap) đ</td>
                                    <td class="text-end fw-bold">@string.Format("{0:N0}", item.GiaBan) đ</td>
                                    <td class="text-center fw-bold text-dark">@item.SoLuongBan</td>
                                    <td class="text-end fw-bold text-dark">@string.Format("{0:N0}", item.DoanhThu) đ</td>
                                    <td class="text-end pe-4 fw-bold text-success">+@string.Format("{0:N0}", item.LoiNhuan) đ</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    <i class="fa-solid fa-file-invoice-dollar d-block fs-1 mb-2 text-secondary opacity-50"></i>
                                    Không có dữ liệu lợi nhuận trong khoảng thời gian này.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>