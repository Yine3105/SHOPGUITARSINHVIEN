@model SHOPGUITAR.Models.SANPHAM
<link href="~/Content/Layout/Guitar.css" rel="stylesheet" />

@{
    ViewBag.Title = "Edit";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}
<div class="edit-wrapper">
    <div style="display:flex; align-items:center; gap:14px;">
        <div style="width:48px; height:48px; border-radius:14px; background:#faeeda; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:22px;">
            ✏️
        </div>
        <div>
            <h2 style="margin:0 0 2px; font-size:28px; font-weight:700; color:#111827;">Chỉnh sửa sản phẩm</h2>
            <p style="margin:0; font-size:13px; color:#6b7280;">Cập nhật thông tin và hình ảnh sản phẩm</p>
        </div>
    </div>
    <hr style="margin-top:16px; border:none; height:1px; background:linear-gradient(to right, #f5a623, rgba(245,166,35,0.25), transparent);" />
    @using (Html.BeginForm(
        "Edit",
        "SanPham",
        FormMethod.Post,
        new { enctype = "multipart/form-data", id = "editForm" }
    ))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.MaSP)
        @Html.HiddenFor(m => m.AnhSP)

        <div class="edit-card">
            <div class="edit-grid">
                <div class="image-panel">
                    <div class="img-preview-box"
                         onclick="document.getElementById('fileInput').click()">
                        <img id="imgPreview"
                             src="@(string.IsNullOrEmpty(Model.AnhSP)
                                ? Url.Content("~/images/no-image.png")
                                : Url.Content("~/images/products/" + Model.AnhSP))" />
                    </div>
                    <input type="file"
                           id="fileInput"
                           name="fileUpload"
                           accept="image/*"
                           onchange="previewImage(event)" />
                    <label for="fileInput" class="upload-label">
                        Chọn ảnh mới
                    </label>

                </div>
                <div class="form-panel">
                    <div class="form-group">
                        <label>Mã sản phẩm</label>
                        @Html.TextBoxFor(
                            m => m.MaSP,
                            new
                            {
                                @class = "form-control",
                                @readonly = "readonly"
                            })
                    </div>
                    <div class="form-group">
                        <label>Tên sản phẩm</label>
                        @Html.TextBoxFor(
                            m => m.TenSP,
                            new
                            {
                                @class = "form-control",
                                placeholder = "Nhập tên sản phẩm"
                            })

                        @Html.ValidationMessageFor(
                            m => m.TenSP,
                            "",
                            new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        <label>Giá bán</label>
                        @Html.TextBoxFor(
                            m => m.GiaBan,
                            new
                            {
                                @class = "form-control",
                                type = "number"
                            })

                        @Html.ValidationMessageFor(
                            m => m.GiaBan,
                            "",
                            new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        <label>Số lượng</label>
                        @Html.TextBoxFor(
                            m => m.SoLuongSP,
                            new
                            {
                                @class = "form-control",
                                type = "number"
                            })

                        @Html.ValidationMessageFor(
                            m => m.SoLuongSP,
                            "",
                            new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        <label>Thương hiệu</label>
                        @Html.TextBoxFor(
                            m => m.ThuongHieu,
                            new
                            {
                                @class = "form-control"
                            })
                    </div>
                    <div class="form-group">
                        <label>Mô tả</label>
                        @Html.TextAreaFor(
                            m => m.MoTaSP,
                            new
                            {
                                @class = "form-control"
                            })
                        @Html.ValidationMessageFor(
                            m => m.MoTaSP,
                            "",
                            new { @class = "text-danger" })
                    </div>
                    <div class="footer-actions">
                        <a href="@Url.Action("Index","SanPham")" class="back-btn">
                            Quay lại
                        </a>
                        <button type="submit" class="btn-save">
                            Lưu thay đổi
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
<script>
    function previewImage(event) {
        const file = event.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = function (e) {
            document.getElementById('imgPreview').src = e.target.result;
        };
        reader.readAsDataURL(file);
    }
</script>